<Window x:Class="WpfApp4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master-Detail: Студенты" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <Border Grid.Column="0" Background="White" Margin="0,0,10,0" CornerRadius="10">
            <StackPanel Margin="10">
                <TextBlock Text="Список студентов" FontWeight="Bold" FontSize="16" Margin="0,5,0,10"/>

                <ListBox x:Name="lstStudents" Margin="0,0,0,10" Height="200" 
                         ItemsSource="{Binding Students}" 
                         SelectedItem="{Binding SelectedStudent, UpdateSourceTrigger=PropertyChanged}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" Padding="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="#E8F0FE" Padding="10" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Добавить нового:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNewName" Margin="0,2" Height="25"/>
                        <TextBox x:Name="txtNewSurname" Margin="0,2" Height="25"/>
                        <Button Content="Добавить" Margin="0,5,0,0" Height="30" 
                                Click="BtnAdd_Click"/>
                    </StackPanel>
                </Border>

                <Button Content="Удалить" Margin="0,5,0,0" Height="30" 
                        Click="BtnDelete_Click" Background="#D32F2F" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- ПРАВАЯ ПАНЕЛЬ -->
        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="30">
            <Grid>
                <TextBlock x:Name="txtNoSelection" 
                           Text="Выберите студента" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Foreground="Gray" FontSize="14"/>

                <StackPanel x:Name="pnlDetails" Visibility="Collapsed">
                    <TextBlock Text="Редактирование студента" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Height="30" x:Name="txtFirstName"
                                 Text="{Binding SelectedStudent.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Height="30" x:Name="txtLastName"
                                 Text="{Binding SelectedStudent.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Возраст:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Height="30" x:Name="txtAge"
                                 Text="{Binding SelectedStudent.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Группа:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Height="30" x:Name="txtGroup"
                                 Text="{Binding SelectedStudent.Group, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- КНОПКА СОХРАНИТЬ -->
                        <Button Grid.Row="4" Grid.Column="1" Content="💾 Сохранить изменения" 
                                Margin="5,15,5,5" Height="35" FontSize="14"
                                Click="BtnSave_Click" Background="#4CAF50" Foreground="White"
                                Cursor="Hand"/>
                    </Grid>

                    <TextBlock x:Name="txtStatus" Text="" Foreground="Green" 
                               Margin="0,10,0,0" FontStyle="Italic" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>