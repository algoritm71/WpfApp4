<Window x:Class="WpfApp4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master-Detail: Студенты" Height="450" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- Конвертер для видимости -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === ЛЕВАЯ ПАНЕЛЬ (MASTER) === -->
        <Border Grid.Column="0" Background="White" Margin="0,0,10,0" CornerRadius="10">
            <StackPanel Margin="10">
                <TextBlock Text="Список студентов" FontWeight="Bold" FontSize="16" Margin="0,5,0,10"/>

                <!-- Список (ListBox) -->
                <ListBox x:Name="lstStudents" Margin="0,0,0,10" Height="200" BorderBrush="#CCCCCC" BorderThickness="1"
                         ItemsSource="{Binding Students}" 
                         SelectedItem="{Binding SelectedStudent}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" Padding="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0078D7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Поля для ДОБАВЛЕНИЯ нового студента -->
                <Border Background="#E8F0FE" Padding="10" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Добавить нового:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#0078D7"/>
                        <TextBox x:Name="txtNewName" Margin="0,2" Height="25" Text="Имя"/>
                        <TextBox x:Name="txtNewSurname" Margin="0,2" Height="25" Text="Фамилия"/>
                        <Button Content="➕ Добавить" Margin="0,5,0,0" Height="30" Background="#0078D7" Foreground="White" 
                                Click="BtnAdd_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Кнопка УДАЛИТЬ -->
                <Button Content="🗑 Удалить выбранного" Margin="0,5,0,0" Height="30" Background="#D32F2F" Foreground="White" 
                        Click="BtnDelete_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- === ПРАВАЯ ПАНЕЛЬ (DETAIL) === -->
        <Border Grid.Column="1" Background="White" CornerRadius="10">
            <Grid Margin="30">
                <!-- Сообщение, если ничего не выбрано -->
                <TextBlock Text="Выберите студента из списка для просмотра и редактирования" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Foreground="Gray" FontSize="14" TextWrapping="Wrap"
                           Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>

                <!-- Форма редактирования (видна только если выбран студент) -->
                <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Редактирование студента" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Имя -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Height="30" 
                                 Text="{Binding SelectedStudent.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Фамилия -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Height="30" 
                                 Text="{Binding SelectedStudent.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Возраст -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Возраст:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Height="30" 
                                 Text="{Binding SelectedStudent.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Группа -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Группа:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Height="30" 
                                 Text="{Binding SelectedStudent.Group, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Text="✓ Изменения сохраняются автоматически при вводе текста." 
                               Foreground="Gray" FontSize="12" Margin="0,10,0,0" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>